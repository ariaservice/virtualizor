{
    "name": "ariaservice/virtualizor",
    "description": "Virtualizor API for Laravel",
    "license": "MIT",
    "authors": [
        {
            "name": "Sajad Mazaheri",
            "email": "me@sajadmazaheri.ir",
            "homepage": "sajadmazaheri.ir"
        }
    ],
    "homepage": "https://github.com/ariaservice/virtualizor",
    "keywords": ["Laravel", "Virtualizor"],
    "require": {
        "illuminate/support": "~7|~8"
    },
    "require-dev": {
        "phpunit/phpunit": "~9.0",
        "orchestra/testbench": "~5|~6"
    },
    "autoload": {
        "psr-4": {
            "Ariaservice\\Virtualizor\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ariaservice\\Virtualizor\\Tests\\": "tests"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ariaservice\\Virtualizor\\VirtualizorServiceProvider"
            ],
            "aliases": {
                "Virtualizor": "Ariaservice\\Virtualizor\\Facades\\Virtualizor"
            }
        }
    }
}
